---
import type { CollectionEntry } from 'astro:content';

interface Props {
    painting: CollectionEntry<'gallery'>;
}

const { painting } = Astro.props
---
<div class="grid-item relative align-bottom mb-10 w-full sm:w-1/2 lg:w-1/4 px-4">
    <img src={painting.data.imageGallery} class="w-full block">
    <div class="absolute bottom-0 left-0 p-10 items-end justify-center font-serif">
        <h1 class="text-3xl text-white">{painting.data.title}</h1>
        <h2 class="text-xl text-zinc-400">{painting.data.author}</h2>
    </div>
</div>